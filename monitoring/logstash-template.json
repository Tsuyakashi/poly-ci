{
    "index_patterns": [
        "nginx-logs-*",
        "apps-logs-*"
    ],
    "template": {
        "settings": {
            "number_of_shards": 1,
            "number_of_replicas": 0
        },
        "mappings": {
            "properties": {
                "@timestamp": {
                    "type": "date"
                },
                "container": {
                    "properties": {
                        "name": {
                            "type": "keyword"
                        }
                    }
                }
            }
        }
    }
}
